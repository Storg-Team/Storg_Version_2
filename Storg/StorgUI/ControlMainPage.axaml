<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             Background="#5A6070" PointerPressed="Lost_Focus" Focusable="True" 
			 x:Class="StorgUI.ControlMainPage">
	<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
			<Grid VerticalAlignment="Stretch" HorizontalAlignment="Left" Background="#363b48">
				<SplitView Name="MainMenu"
							IsPaneOpen="False"
				           OpenPaneLength="250"
				           CompactPaneLength="70"
				           Background="#363b48"
				           PaneBackground="#363b48"
				           DisplayMode="CompactInline"
							HorizontalContentAlignment="Stretch">
					<SplitView.Pane>
						<StackPanel VerticalAlignment="Top" Margin="5,50,5,0">
							<ListBox>
								<ListBoxItem Name="BtAccueil" Background="#d6bebe"  Classes="DefaultBt" Focusable="True">
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<Image Source="/Resources/logo_accueil.png" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="0, 0, 15,0" Width="35" Height="35"/>
										<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">Accueil</TextBlock>
									</StackPanel>
								</ListBoxItem>
								<ListBoxItem Name="BtSettings"  Background="#d6bebe"  Classes="DefaultBt" Focusable="True">
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<Image Source="/Resources/settings.png" HorizontalAlignment="Left" Margin="0, 0, 15,0" Width="35" Height="35"/>
										<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">Paramètres</TextBlock>
									</StackPanel>
								</ListBoxItem>
								<ListBoxItem Name="BtAide"  Background="#d6bebe"  Classes="DefaultBt" Focusable="True">
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<Image Source="/Resources/logo_help.png" HorizontalAlignment="Left" Margin="0, 0, 15,0" Width="35" Height="35"/>
										<TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">Aide</TextBlock>
									</StackPanel>
								</ListBoxItem>
								<ListBoxItem Name="BtAProps" Background="#d6bebe"  Classes="DefaultBt" Focusable="True">
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<Image Source="/Resources/logo_a_propos.png" HorizontalAlignment="Left" Margin="0, 0, 15,0" Width="35" Height="35"/>
										<TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">A propos</TextBlock>
									</StackPanel>
								</ListBoxItem>
								<ListBoxItem Name="BtLiveDecomp" Background="#d6bebe"  Classes="DefaultBt" Focusable="True">
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<Image Source="avares://StorgUI/Resources/folder-input.png " HorizontalAlignment="Left" Margin="0, 0, 15,0" Width="35" Height="35"/>
										<TextBlock HorizontalAlignment="Left" VerticalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">Live décompression</TextBlock>
									</StackPanel>
								</ListBoxItem>
							</ListBox>
				</StackPanel>
					</SplitView.Pane>
					<SplitView.Content>
						<Border CornerRadius="15, 0, 0, 0" Background="#5A6070" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
							<ContentControl x:Name="MainContent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
							
							<StackPanel Orientation="Vertical" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
					<Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="10,22,0,0">
						<Grid HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,10,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="325"/>
							</Grid.ColumnDefinitions>
							<Grid.RowDefinitions>
								<RowDefinition Height="30"/>
							</Grid.RowDefinitions>
							<TextBox VerticalContentAlignment="Center" Height="40" Grid.Column="0" Grid.Row="0" Margin="0,0,10,0" CornerRadius="60" Foreground="Black" Classes="Search" x:Name="Search" GotFocus="Focus" LostFocus="NoFocus" KeyDown="TriggerKeyResearch" FontFamily="avares://StorgUI/Resources/Poppins/Poppins-Bold.ttf#Poppins">
								Rechercher des fichiers compressés
							</TextBox>
							<Button Name="BtResearch" HorizontalAlignment="Right" Width="40" Height="40" Padding="30, 0, 0, 0" Margin="0,0,10,0" CornerRadius="100" Classes="DefaultBt" Background="#d6bebe">
							<Image Grid.Column="0" Grid.Row="0" Margin="0,0,20,0" Source="/Resources/search.png" HorizontalAlignment="Right" Width="25" Height="25"/>
							</Button>
						</Grid>
						<StackPanel Orientation="Horizontal" Margin="330,0,0,0" Spacing="20">
							<Button Width="40" Height="40" CornerRadius="30" HorizontalAlignment="Left" VerticalAlignment="Center" Name="btnReload" Background="#d6bebe" Classes="DefaultBt"  ToolTip.Tip="Actualiser">
								<Image Width="30" Height="30" Source="/Resources/reload.png"/>
							</Button>
							<Button Name="btnTelecharger" IsVisible="False" Width="40" Height="40" CornerRadius="30" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#d6bebe" Classes="DefaultBt" ToolTip.Tip="Télécharger">
								<Image Source="Resources/download.png" Width="25" Height="25" ></Image>
							</Button>
							<Button Name="btnSupprimer" IsVisible="False" Width="40" Height="40" CornerRadius="30" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#d6bebe" Classes="DefaultBt" ToolTip.Tip="Supprimer">
								<Image Source="Resources/trash-2.png" Width="25" Height="25"></Image>
							</Button>
							<Button Name="btnUpload" Width="40" Height="40" CornerRadius="30" HorizontalAlignment="Left" VerticalAlignment="Center" Background="#d6bebe" Classes="DefaultBt" ToolTip.Tip="Transferer" IsVisible="False">
								<Image  Source="Resources/hard-drive-upload.png" Width="25" Height="25"/>
							</Button>
						</StackPanel>
						<Button Name="btnFetch" HorizontalAlignment="Right" VerticalAlignment="Center" CornerRadius="30" Width="40" Height="40" Background="#d6bebe" Classes="DefaultBt" Margin="0,0,10,0" ToolTip.Tip="Récupérer fichiers transférer" IsVisible="False"> 
							<Image Source="Resources/cloud-backup.png" Width="25" Height="25"/>
						</Button>
					</Grid>
						<DataGrid x:Name="FilesGrid" 
						          VerticalAlignment="Stretch" 
						          BorderThickness="1"
						          IsReadOnly="True"
						          IsVisible="True"
						          Margin="20,20,20,45"
						          AutoGenerateColumns="False"
						          MinHeight="35"
						          VerticalScrollBarVisibility="Auto">
						</DataGrid>

						<ProgressBar Name="LoadingBar" Minimum="0" Maximum="100" Margin="10, -100 , 10, 10" ShowProgressText="True" Height="20" Value="0" Foreground="#0eba2f" IsVisible="True"/>

					<Grid>
					<Grid Name="dragDrop" Background="#d6bebe" DragDrop.AllowDrop="True" HorizontalAlignment="Stretch" Height="190" Margin="0,-40,0,0" PointerPressed="FileBrowser">
						<Rectangle StrokeDashArray="5, 3" Stroke="Black" StrokeThickness="3"></Rectangle>
						<TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">Déposez ici / Cliquez pour parcourir</TextBlock>
					</Grid>
						<Grid Name="folderImport" VerticalAlignment="Bottom" HorizontalAlignment="Center" Background="#c0a7a7">
							<Rectangle StrokeDashArray="5, 3" Stroke="Black" StrokeThickness="3" Width="300" Height="40"></Rectangle>
							<TextBlock VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Black" FontFamily="Resources/Poppins/Poppins-Bold.ttf#Poppins">Importer le contenu d'un dossier</TextBlock>
						</Grid>
					</Grid>
				</StackPanel>
							
			</ContentControl>
						</Border>
					</SplitView.Content>
					
				</SplitView>
			</Grid>
			
		</Grid>
</UserControl>

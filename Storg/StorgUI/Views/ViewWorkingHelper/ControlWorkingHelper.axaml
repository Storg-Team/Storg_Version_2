<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Background="{DynamicResource AppBackground}"
             x:Class="StorgUI.ControlWorkingHelper">
		<ScrollViewer VerticalScrollBarVisibility="Visible" Name="ScollBar" Margin="20, 40,0,0" HorizontalAlignment="Stretch">
				<StackPanel Orientation="Vertical" Margin="0,20,0,0">
					<TextBlock Text="Rechercher :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
					<Grid ColumnDefinitions="Auto, *">
					<Image Grid.Column="0" Source="/Resources/ImageHelper/bouton_recherche.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="La barre de recherche vous permet de naviguer dans les fichiers listés au milieu de la page." Foreground="{DynamicResource AppForeground}" VerticalAlignment="Top" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="20,0,10,0" Classes="Text"/>
					</Grid>
					<TextBlock Text="Actualiser :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
					<Grid ColumnDefinitions="Auto, *">
						<Image Grid.Column="0" Source="/Resources/ImageHelper/bouton_Parametres.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="Le bouton de rafraichissement vous permet d’actualiser la liste des fichiers." Foreground="{DynamicResource AppForeground}" VerticalAlignment="Top" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="20,0,0,0" Classes="Text"/>
					</Grid>
					<TextBlock Text="Navigateur de fichier :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
						<Grid ColumnDefinitions="Auto, *">
						<Image Grid.Column="0" Source="/Resources/ImageHelper/selecteur_fichier.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="Le navigateur de fichier est situé au milieu de la page, c’est là où vous pouvez y trouver vos différents fichiers compressés." Foreground="{DynamicResource AppForeground}" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" Margin="20,0,0,0"/>
						</Grid>
					<TextBlock Text="Déposez ici :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
						<Grid ColumnDefinitions="Auto, *">
						<Image Grid.Column="0" Source="/Resources/ImageHelper/Drag_drop.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="Le drag and drop vous permet de directement glisser vos fichiers dans cette zone en effectuant un clic gauche maintenu et en ramenant le fichier souhaité." Foreground="{DynamicResource AppForeground}" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" Margin="20,0,0,0"/>
						</Grid>
					<TextBlock Text="Exportation :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
						<Grid ColumnDefinitions="Auto, *">
						<Image Grid.Column="0" Source="/Resources/ImageHelper/Exporter.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="Le bouton Exporter permet d’exporter le fichier sous forme compressée dans votre dossier Téléchargement de votre ordinateur, cela peut être utile pour envoyer un lourd." Foreground="{DynamicResource AppForeground}" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" Margin="20,0,0,0"/>
						</Grid>
					<TextBlock Text="Téléchargement :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
						<Grid ColumnDefinitions="Auto, *">
						<Image Grid.Column="0" Source="/Resources/ImageHelper/Telecharger.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="Le bouton Télécharger permet de récupérer le fichier décompressé." Foreground="{DynamicResource AppForeground}" VerticalAlignment="Top" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="20,0,0,0"/>
						</Grid>
					<TextBlock Text="Suppression :" FontSize="30" Foreground="{DynamicResource AppForeground}" FontFamily="avares://StorgUI/Resources/Montserrat/Montserrat-Bold.ttf#Montserrat"/>
						<Grid ColumnDefinitions="Auto, *">
						<Image Grid.Column="0" Source="/Resources/ImageHelper/Supprimer.png" Width="400" Height="300" VerticalAlignment="Top"/>
						<TextBlock Grid.Column="1" Text="Le bouton Supprimer permet de supprimer les fichiers listés dans le sélecteur de fichiers." Foreground="{DynamicResource AppForeground}" HorizontalAlignment="Left" VerticalAlignment="Top" TextWrapping="Wrap" Margin="20,0,0,0"/>
						</Grid>
				</StackPanel>
		</ScrollViewer>
</UserControl>
